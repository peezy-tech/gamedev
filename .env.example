# The URL of the world server
WORLD_URL=http://localhost:3000

# The world id (local worlds should start with local-)
WORLD_ID=local-xxxxxxxxxx

# The port the server runs on
PORT=3000
WORLD=world

# The secret the server uses to create/parse json web tokens
JWT_SECRET=hyper

# The code used to become admin in the world (type /admin <code> in chat)
# If left blank, everyone is an admin!
ADMIN_CODE=

# How often the world saves (seconds) 
# Can be set to 0 to disable saving
SAVE_INTERVAL=60

# Whether players should collide with other players
PUBLIC_PLAYER_COLLISION=false

# The maximum upload file size for models etc (mb)
PUBLIC_MAX_UPLOAD_SIZE=12

# The public url used by clients to access api (eg upload assets)
PUBLIC_API_URL=http://localhost:3000/api

# Optional public websocket URL. If unset, runtime derives it from PUBLIC_API_URL.
PUBLIC_WS_URL=ws://localhost:3000/ws

# Optional hosted-runtime bootstrap endpoint.
# Legacy pull-bootstrap endpoint for platform-managed worlds.
# Standby/push mode will replace this with POST /internal/bootstrap.
# Expected form: https://<host>/api/internal/runtime/bootstrap
RUNTIME_BOOTSTRAP_URL=

# Optional control-plane base URL for runtime callbacks into world-service.
# Local runtimes can set this directly.
# Hosted runtimes should receive this from the bootstrap payload.
CONTROL_INTERNAL_BASE_URL=

# Optional auth base URL for lobby identity mode.
# Local runtimes can set this directly.
# Hosted runtimes typically receive this via the bootstrap payload.
PUBLIC_AUTH_URL=

# Managed-runtime bootstrap auth identity.
# Agones should inject RUNTIME_BOOTSTRAP_INSTANCE_ID from pod metadata.name.
# RUNTIME_BOOTSTRAP_AUTH_SECRET defaults to JWT_SECRET when unset.
RUNTIME_BOOTSTRAP_INSTANCE_ID=
RUNTIME_BOOTSTRAP_AUTH_SECRET=

# Runtime session token TTL (seconds)
RUNTIME_SESSION_TTL_SECONDS=604800

# Optional direct WSS/TLS settings.
# If TLS_CERT_PATH and TLS_KEY_PATH are set, server runs HTTPS.
# If DIRECT_WSS_PORT is also set, PORT stays HTTP and DIRECT_WSS_PORT serves HTTPS/WSS.
DIRECT_WSS_PORT=
TLS_CERT_PATH=
TLS_KEY_PATH=

# How assets are stored, fetched and uploaded (local or s3)
ASSETS=local
ASSETS_BASE_URL=http://localhost:3000/assets
ASSETS_S3_URI=

# By default world data is stored in a local sqlite database in the world folder
# Optionally set this to a postgres uri to store remotely, eg `postgres://username:password@host:port/database`
DB_URI=local
DB_SCHEMA=

# Whether the server should do a cleanup of unused blueprints and assets before launching
CLEAN=true

# LiveKit (voice chat)
LIVEKIT_WS_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Hooks to connect to a local app dev server
PUBLIC_DEV_SERVER=false

# Registry (public directory)
# Set REGISTRY_ENABLED=false to opt out of listing
REGISTRY_ENABLED=true
# Registry base URL (optional override)
REGISTRY_URL=
# Optional: explicit join URL for the world (must be https, no custom port)
REGISTRY_JOIN_URL=
