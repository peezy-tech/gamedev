# The URL of the world server
WORLD_URL=http://localhost:3000

# The world id (local worlds should start with local-)
WORLD_ID=local-xxxxxxxxxx

# The port the server runs on
PORT=3000
WORLD=world

# The secret the server uses to create/parse json web tokens
JWT_SECRET=hyper

# The code used to become admin in the world (type /admin <code> in chat)
# Bootstrapped/managed runtimes ignore admin-code auth and rely on account roles instead.
# If left blank on a standalone world, everyone is an admin!
ADMIN_CODE=

# How often the world saves (seconds)
# Can be set to 0 to disable saving
SAVE_INTERVAL=60

# Whether players should collide with other players
PUBLIC_PLAYER_COLLISION=false

# The maximum upload file size for models etc (mb)
PUBLIC_MAX_UPLOAD_SIZE=12

# The public url used by clients to access api (eg upload assets)
PUBLIC_API_URL=http://localhost:3000/api

# Optional public websocket URL. If unset, runtime derives it from PUBLIC_API_URL.
PUBLIC_WS_URL=ws://localhost:3000/ws

# Optional hosted-runtime bootstrap endpoint.
# Required when RUNTIME_BOOTSTRAP_MODE=pull for the startup fetch path.
# Push mode ignores this and waits for POST /internal/bootstrap instead.
# Expected form: https://<host>/api/internal/runtime/bootstrap
RUNTIME_BOOTSTRAP_URL=

# Optional managed-runtime bootstrap mode.
# Set pull to fetch the binding at startup, or push to boot into standby and wait for /internal/bootstrap.
# Leave unset only for local/static worlds that boot directly from env.
RUNTIME_BOOTSTRAP_MODE=

# Optional step-level debug logging for hosted runtime bootstrap.
# Set to 1 to emit structured runtime logs around metadata fetch, binding apply, and initialization stages.
RUNTIME_BOOTSTRAP_DEBUG=

# Optional control-plane base URL for runtime callbacks into world-service.
# Local runtimes can set this directly.
# Hosted runtimes should receive this from the bootstrap payload.
CONTROL_INTERNAL_BASE_URL=

# Optional auth base URL for lobby identity mode.
# Local runtimes can set this directly.
# Hosted runtimes typically receive this via the bootstrap payload.
PUBLIC_AUTH_URL=

# Standalone wallet identity mode.
# Set STANDALONE_WALLET_AUTH=true and PUBLIC_AUTH_URL=<runtime>/api/auth/identity
# to use the runtime's built-in SIWE identity endpoints without world-service.
STANDALONE_WALLET_AUTH=false
# Standalone wallet mode requires wallet auth by default. Set REQUIRE_WALLET_AUTH=false to allow guests.
REQUIRE_WALLET_AUTH=
PUBLIC_REQUIRE_WALLET_AUTH=
# Comma-separated static client origins allowed to use credentialed wallet auth.
CORS_ORIGINS=
STANDALONE_ADMIN_WALLETS=
STANDALONE_BUILDER_WALLETS=
# Set to false for same-origin local HTTP testing. HTTPS static clients should keep the default.
STANDALONE_AUTH_COOKIE_SECURE=

# Static client builds use this to resolve built-in public assets from a nested game-trove file URL.
PUBLIC_ASSET_BASE=

# Optional game-trove runtime assignment endpoint for static clients.
# If unset, game-trove-hosted clients read the parent shell bootstrap URL and discover it there.
PUBLIC_RUNTIME_ASSIGNMENT_URL=
PUBLIC_RUNTIME_ASSIGNMENT_MODE=
PUBLIC_RUNTIME_MATCH_KEY=
PUBLIC_RUNTIME_REGION=
PUBLIC_RUNTIME_PLAYER_ID=

# Optional runtime descriptor mode for game-trove publishing.
# Set GAME_PROTOCOL_RUNTIME_KIND=authoritative-session when runtime-control should allocate Agones instances.
GAME_PROTOCOL_RUNTIME_KIND=external-authoritative
GAME_PROTOCOL_RUNTIME_IMAGE=
GAME_PROTOCOL_RUNTIME_PORT=3000
GAME_PROTOCOL_RUNTIME_CAPACITY=
GAME_PROTOCOL_RUNTIME_PROTOCOL=wss
GAME_PROTOCOL_RUNTIME_HEALTH_PATH=/health
GAME_PROTOCOL_RUNTIME_WS_PATH=/ws
GAME_PROTOCOL_RUNTIME_REGIONS=use
GAME_PROTOCOL_RUNTIME_BOOTSTRAP_MODE=
GAME_PROTOCOL_RUNTIME_WORLD_ID=
GAME_PROTOCOL_RUNTIME_WORLD_SLUG=
GAME_PROTOCOL_RUNTIME_DB_SCHEMA=
GAME_PROTOCOL_RUNTIME_PUBLIC_MAX_UPLOAD_SIZE=
GAME_PROTOCOL_RUNTIME_SHUTDOWN_IDLE_SECONDS=
GAME_PROTOCOL_RUNTIME_ENV=
GAME_PROTOCOL_RUNTIME_SECRET_ENV=
GAME_PROTOCOL_RUNTIME_KUBERNETES=

# Managed-runtime bootstrap auth identity.
# Agones should inject RUNTIME_BOOTSTRAP_INSTANCE_ID from pod metadata.name.
# RUNTIME_BOOTSTRAP_AUTH_SECRET defaults to JWT_SECRET when unset.
RUNTIME_BOOTSTRAP_INSTANCE_ID=
RUNTIME_BOOTSTRAP_AUTH_SECRET=

# Runtime session token TTL (seconds)
RUNTIME_SESSION_TTL_SECONDS=2592000

# Optional direct WSS/TLS settings.
# If TLS_CERT_PATH and TLS_KEY_PATH are set, server runs HTTPS.
# If DIRECT_WSS_PORT is also set, PORT stays HTTP and DIRECT_WSS_PORT serves HTTPS/WSS.
DIRECT_WSS_PORT=
TLS_CERT_PATH=
TLS_KEY_PATH=

# How assets are stored, fetched and uploaded (local, s3, or asset-service)
ASSETS=local
# For ASSETS=asset-service, prefer the runtime /assets URL so named built-in
# engine assets are served locally and hashed uploads proxy to asset-service.
ASSETS_BASE_URL=http://localhost:3000/assets
ASSETS_S3_URI=
ASSET_SERVICE_URL=
ASSET_SERVICE_API_KEY=

# Optional server-only public Hyperliquid market-data service.
# Browser clients do not use this; they continue to connect to Hyperliquid directly.
HYPERLIQUID_DATA_URL=

# By default world data is stored in a local sqlite database in the world folder
# Optionally set this to a postgres uri to store remotely, eg `postgres://username:password@host:port/database`
DB_URI=local
DB_SCHEMA=

# Whether the server should do a cleanup of unused blueprints and assets before launching
CLEAN=true

# LiveKit (voice chat)
LIVEKIT_WS_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Hooks to connect to a local app dev server
PUBLIC_DEV_SERVER=false

# Registry (public directory)
# Set REGISTRY_ENABLED=false to opt out of listing
REGISTRY_ENABLED=true
# Registry base URL (optional override)
REGISTRY_URL=
# Optional: explicit join URL for the world (must be https, no custom port)
REGISTRY_JOIN_URL=
