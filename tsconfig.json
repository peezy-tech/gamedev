{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@firebolt-dev/jsx",
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": ["*.js", "*.mjs", "*.ts", "packages/**/*.js", "scripts/**/*.mjs", "test/**/*.js"],
  "exclude": ["build", "node_modules", "packages/core/libs", "packages/core/physx-js-webidl.js"]
}
