{
  "name": "gamedev",
  "version": "0.3.3",
  "type": "module",
  "packageManager": "bun@1.2.14",
  "workspaces": {
    "packages": [
      "packages/*"
    ]
  },
  "main": "index.node.js",
  "types": "index.d.ts",
  "files": [
    "build/**",
    "docs/**",
    "packages/**",
    "scripts/**",
    "index.node.js",
    "index.node-client.js",
    "index.d.ts",
    "index.node-client.d.ts",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.node.js",
      "require": "./index.node.js",
      "default": "./index.node.js"
    },
    "./node-client": {
      "types": "./index.node-client.d.ts",
      "import": "./index.node-client.js",
      "require": "./index.node-client.js",
      "default": "./index.node-client.js"
    }
  },
  "homepage": "https://github.com/lobby-ws/gamedev#readme",
  "bugs": {
    "url": "https://github.com/lobby-ws/gamedev/issues"
  },
  "keywords": [
    "hyperfy",
    "3d",
    "components",
    "virtual-worlds",
    "metaverse",
    "three.js",
    "webgl",
    "real-time"
  ],
  "scripts": {
    "dev:runtime": "bun run scripts/build.mjs --dev",
    "runtime:bootstrap": "bun run scripts/bootstrap-runtime.mjs",
    "runtime:bootstrap:dev": "bun run scripts/bootstrap-runtime.mjs --run dev",
    "runtime:bootstrap:start": "bun run scripts/bootstrap-runtime.mjs --run start",
    "dev:app-server": "bun run scripts/dev-app-server.mjs",
    "dev": "bun run scripts/dev.mjs",
    "build": "bun run scripts/build.mjs",
    "start": "bun run scripts/start-runtime.mjs",
    "prepublishOnly": "bun run build",
    "world:backup": "bun run scripts/backup-world.mjs",
    "static:build": "bun run scripts/build-static.mjs",
    "viewer:dev": "bun run scripts/build-viewer.mjs --dev",
    "viewer:build": "bun run scripts/build-viewer.mjs",
    "client:dev": "bun run scripts/build-client.mjs --dev",
    "client:build": "bun run scripts/build-client.mjs",
    "client:build:platform": "bun run scripts/build.mjs --client-only",
    "node-client:dev": "bun run scripts/build-node-client.mjs --dev",
    "node-client:build": "bun run scripts/build-node-client.mjs",
    "lint": "eslint . --ext .js,.jsx",
    "lint:fix": "eslint . --ext .js,.jsx --fix",
    "format": "prettier --write .",
    "check": "bun run lint && bun run format",
    "test": "bun test test/integration/**/*.test.js",
    "test:integration": "bun test test/integration/**/*.test.js",
    "smoke:matrix": "bun run scripts/smoke-mode-matrix.mjs"
  },
  "bin": {
    "gamedev": "packages/cli/gamedev.mjs"
  },
  "dependencies": {
    "@gamedev/core": "workspace:*",
    "@gamedev/server": "workspace:*",
    "@ai-sdk/anthropic": "^3.0.23",
    "@ai-sdk/openai": "^3.0.18",
    "@aws-sdk/client-s3": "^3.859.0",
    "@fastify/compress": "^8.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.0.1",
    "@fastify/static": "^8.0.1",
    "@fastify/websocket": "^11.0.1",
    "@firebolt-dev/css": "^0.4.3",
    "@firebolt-dev/jsx": "^0.4.3",
    "@nktkas/hyperliquid": "0.30.2",
    "@pixiv/three-vrm": "^3.3.3",
    "@privy-io/chains": "0.1.1",
    "@privy-io/react-auth": "^3.13.1",
    "@solana-program/memo": "^0.11.0",
    "@solana-program/system": "^0.12.0",
    "@solana-program/token": "^0.11.0",
    "@solana/kit": "^6.1.0",
    "@sparkjsdev/spark": "^0.1.10",
    "@tanstack/react-query": "^5.90.2",
    "acorn": "^8.15.0",
    "ai": "^6.0.49",
    "better-sqlite3": "^11.7.2",
    "d3": "^7.9.0",
    "dotenv-flow": "^4.1.0",
    "esbuild-plugin-polyfill-node": "^0.3.0",
    "ethers": "^6.16.0",
    "eventemitter3": "^5.0.1",
    "fastify": "^5.0.0",
    "find-cache-dir": "^5.0.0",
    "fs-extra": "^11.2.0",
    "hls.js": "^1.6.1",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "livekit-client": "^2.9.9",
    "livekit-server-sdk": "^2.11.0",
    "lodash": "^4.17.23",
    "lodash-es": "^4.17.21",
    "lucide-react": "^0.469.0",
    "moment": "^2.30.1",
    "msgpackr": "^1.11.0",
    "n8ao": "^1.10.0",
    "nanoid": "^5.0.6",
    "pg": "^8.16.3",
    "postprocessing": "^6.36.4",
    "react": "^19.1.0",
    "react-colorful": "^5.6.1",
    "react-dom": "^19.1.0",
    "ses": "^1.10.0",
    "siwe": "^2.3.2",
    "source-map-support": "^0.5.21",
    "three": "^0.173.0",
    "three-mesh-bvh": "^0.8.3",
    "viem": "^2.46.3",
    "ws": "^8.18.3",
    "yoga-layout": "^3.2.1"
  },
  "devDependencies": {
    "@gamedev/app-server": "workspace:*",
    "@gamedev/client": "workspace:*",
    "@babel/eslint-parser": "^7.23.10",
    "@babel/preset-react": "^7.23.10",
    "esbuild": "^0.24.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.4.2"
  },
  "engines": {
    "bun": ">=1.2.14"
  },
  "trustedDependencies": [
    "@reown/appkit",
    "better-sqlite3",
    "bufferutil",
    "esbuild",
    "keccak",
    "msgpackr-extract",
    "utf-8-validate"
  ],
  "overrides": {
    "three": "^0.173.0"
  },
  "license": "GPL-3.0-only"
}
