{
  "name": "gamedev",
  "version": "0.3.4",
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "main": "index.node.js",
  "types": "index.d.ts",
  "files": [
    "build/**",
    "docs/**",
    "packages/**",
    "scripts/**",
    "index.node.js",
    "index.node-client.js",
    "index.d.ts",
    "index.node-client.d.ts",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.node.js",
      "require": "./index.node.js",
      "default": "./index.node.js"
    },
    "./node-client": {
      "types": "./index.node-client.d.ts",
      "import": "./index.node-client.js",
      "require": "./index.node-client.js",
      "default": "./index.node-client.js"
    }
  },
  "homepage": "https://github.com/lobby-ws/gamedev#readme",
  "bugs": {
    "url": "https://github.com/lobby-ws/gamedev/issues"
  },
  "keywords": [
    "hyperfy",
    "3d",
    "components",
    "virtual-worlds",
    "metaverse",
    "three.js",
    "webgl",
    "real-time"
  ],
  "scripts": {
    "dev:runtime": "node scripts/build.mjs --dev",
    "runtime:bootstrap": "node scripts/bootstrap-runtime.mjs",
    "runtime:bootstrap:dev": "node scripts/bootstrap-runtime.mjs --run dev",
    "runtime:bootstrap:start": "node scripts/bootstrap-runtime.mjs --run start",
    "dev:app-server": "bash -c 'mkdir -p project; if [ ! -f project/.env ]; then if [ -f .env ]; then cp .env project/.env; elif [ -f .env.example ]; then cp .env.example project/.env; fi; fi; (cd project && node ../packages/cli/gamedev.mjs app-server)'",
    "dev": "bash -c 'vp run dev:runtime & vp run dev:app-server & wait'",
    "build": "node scripts/build.mjs",
    "start": "node build/index.js",
    "prepublishOnly": "vp run build",
    "world:backup": "node scripts/backup-world.mjs",
    "static:build": "node scripts/build-static.mjs",
    "viewer:dev": "node scripts/build-viewer.mjs --dev",
    "viewer:build": "node scripts/build-viewer.mjs",
    "client:dev": "node scripts/build-client.mjs --dev",
    "client:build": "node scripts/build-client.mjs",
    "client:build:platform": "node scripts/build.mjs --client-only",
    "node-client:dev": "node scripts/build-node-client.mjs --dev",
    "node-client:build": "node scripts/build-node-client.mjs",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "format": "vp fmt --write .",
    "format:check": "vp fmt --check .",
    "check": "vp check",
    "test": "node --test --loader ./scripts/node-esm-loader.mjs \"test/integration/**/*.test.js\"",
    "test:integration": "node --test --loader ./scripts/node-esm-loader.mjs \"test/integration/**/*.test.js\"",
    "smoke:matrix": "node scripts/smoke-mode-matrix.mjs"
  },
  "bin": {
    "gamedev": "packages/cli/gamedev.mjs"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.23",
    "@ai-sdk/openai": "^3.0.18",
    "@aws-sdk/client-s3": "^3.859.0",
    "@fastify/compress": "^8.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.0.1",
    "@fastify/static": "^8.0.1",
    "@fastify/websocket": "^11.0.1",
    "@firebolt-dev/css": "^0.4.3",
    "@firebolt-dev/jsx": "^0.4.3",
    "@nktkas/hyperliquid": "0.30.2",
    "@pixiv/three-vrm": "^3.3.3",
    "@privy-io/chains": "0.1.1",
    "@privy-io/react-auth": "^3.13.1",
    "@solana-program/memo": "^0.11.0",
    "@solana-program/system": "^0.12.0",
    "@solana-program/token": "^0.11.0",
    "@solana/kit": "^6.1.0",
    "@sparkjsdev/spark": "^0.1.10",
    "@tanstack/react-query": "^5.90.2",
    "acorn": "^8.15.0",
    "ai": "^6.0.49",
    "better-sqlite3": "^11.7.2",
    "d3": "^7.9.0",
    "dotenv-flow": "^4.1.0",
    "esbuild-plugin-polyfill-node": "^0.3.0",
    "ethers": "^6.16.0",
    "eventemitter3": "^5.0.1",
    "fastify": "^5.0.0",
    "find-cache-dir": "^5.0.0",
    "fs-extra": "^11.2.0",
    "hls.js": "^1.6.1",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "livekit-client": "^2.9.9",
    "livekit-server-sdk": "^2.11.0",
    "lodash": "^4.17.23",
    "lodash-es": "^4.17.21",
    "lucide-react": "^0.469.0",
    "moment": "^2.30.1",
    "msgpackr": "^1.11.0",
    "n8ao": "^1.10.0",
    "nanoid": "^5.0.6",
    "pg": "^8.16.3",
    "postprocessing": "^6.36.4",
    "react": "^19.1.0",
    "react-colorful": "^5.6.1",
    "react-dom": "^19.1.0",
    "ses": "^1.10.0",
    "siwe": "^2.3.2",
    "source-map-support": "^0.5.21",
    "three": "^0.173.0",
    "three-mesh-bvh": "^0.8.3",
    "viem": "^2.46.3",
    "ws": "^8.18.3",
    "yoga-layout": "^3.2.1"
  },
  "devDependencies": {
    "@gamedev/app-server": "workspace:*",
    "@gamedev/client": "workspace:*",
    "@gamedev/core": "workspace:*",
    "@gamedev/server": "workspace:*",
    "@types/node": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "esbuild": "^0.24.0",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "engines": {
    "npm": ">=10.0.0",
    "node": "24.15.0"
  },
  "overrides": {
    "three": "^0.173.0"
  },
  "license": "GPL-3.0-only"
}
